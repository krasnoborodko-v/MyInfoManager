{
  "name": "myinfomanager-desktop",
  "version": "1.0.0",
  "description": "MyInfoManager Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.myinfomanager.desktop",
    "productName": "MyInfoManager",
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../sidebar/build",
        "to": "frontend"
      },
      {
        "from": "../server",
        "to": "server"
      },
      {
        "from": "../db",
        "to": "db"
      },
      {
        "from": "../launcher.py",
        "to": "launcher.py"
      },
      {
        "from": "../requirements.txt",
        "to": "requirements.txt"
      }
    ]
  }
}
